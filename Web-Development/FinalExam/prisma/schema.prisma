generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  category_id Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  dishes      Dish[]

  @@map("categories")
}

model Chef {
  chef_id    Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  specialty  String?   @db.VarChar(255)
  bio        String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  dishes     Dish[]

  @@map("chefs")
}

model Dish {
  dish_id                  Int       @id @default(autoincrement())
  dish_name                String    @db.VarChar(500)
  description              String
  image_url                String?   @db.VarChar(1000)
  chef_id                  Int?
  category_id              Int?
  rating                   Decimal?  @db.Decimal(2, 1)
  total_reviews            Int?      @default(0)
  preparation_time_minutes Int
  serving_size             Int
  current_price            Decimal   @db.Decimal(10, 2)
  original_price           Decimal   @db.Decimal(10, 2)
  is_featured              Boolean?  @default(false)
  created_at               DateTime? @default(now()) @db.Timestamp(6)
  category                 Category? @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction)
  chef                     Chef?     @relation(fields: [chef_id], references: [chef_id], onDelete: NoAction, onUpdate: NoAction)

  @@map("dishes")
}
